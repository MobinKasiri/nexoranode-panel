# ─── Shared with bot (MUST be identical in /opt/nexoranode-bot/.env) ─────────
# Run on server: docker inspect nexoranode-postgres --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}}{{end}}'
DOCKER_NETWORK=deploy_nexora_net

# ─── Database ─────────────────────────────────────────────────────────────────
# Host MUST be container name nexoranode-postgres (not postgres / localhost)
DATABASE_URL=postgresql+asyncpg://nexora:CHANGE_ME@nexoranode-postgres:5432/nexorabot

ENVIRONMENT=production

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=generate-strong-random-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
JWT_REFRESH_DAYS=30

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_FULLNAME=مدیر

# ─── 3X-UI / Xray panel (NOT manage.nexoranode.xyz:2053 admin UI) ───────────
# Public: https://p.nexoranode.xyz:2057/F9Ax1FO5Oh7yWLk8Ww/
# Same server (panel API in Docker): https://127.0.0.1:2057
XUI_HOST=https://p.nexoranode.xyz:2057
XUI_PATH=/F9Ax1FO5Oh7yWLk8Ww
XUI_USERNAME=
XUI_PASSWORD=
XUI_TOKEN=
# Subscription link base — same value as bot .env (must end with /s/).
XUI_SUB_BASE_URL=https://sub.manchesterchocolates.ir/s/
# Leave empty = attach purchases to all enabled panel inbounds
# XUI_INBOUND_FILTER=🇩🇪 NX AC,🇵🇱 PL-N1

# Same token as the Telegram bot (required for receipt photos from Telegram).
# If empty, panel reads /bot/.env automatically.
BOT_TOKEN=
BOT_API_URL=https://api.telegram.org/bot

# ─── Nexoranode admin panel (this repo) ──────────────────────────────────────
FRONTEND_URL=https://manage.nexoranode.xyz:2053
BOT_ROOT=/bot
BOT_ROOT_HOST=/opt/nexoranode-bot
BOT_DATA_DIR=/data/plans
PLANS_FILE=/data/plans/plans.json
PLANS_DIR_HOST=/opt/nexoranode-data

# Payment — optional here; panel reads /bot/.env if empty
CARD_NUMBER=
CARD_OWNER=
CARD_BANK=

REFERRAL_BONUS_TOMAN=8000
REFERRAL_FRIEND_BONUS_TOMAN=5000
QUANTITY_MAX=20

NEXT_PUBLIC_API_URL=https://manage.nexoranode.xyz:2053/api
NEXT_PUBLIC_APP_NAME=Nexoranode Admin
CSRF_SECRET=generate-csrf-secret-here
