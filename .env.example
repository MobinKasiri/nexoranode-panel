# Database (same as bot)
# IMPORTANT: use container name "nexoranode-postgres", NOT "postgres" or "localhost"
# (panel runs in a separate compose stack — service names don't resolve across stacks)
DATABASE_URL=postgresql+asyncpg://nexora:CHANGE_ME@nexoranode-postgres:5432/nexorabot

# Docker network shared with bot (run: docker network ls | grep nexora)
NEXORA_DOCKER_NETWORK=deploy_nexora_net

ENVIRONMENT=production

# JWT
JWT_SECRET=generate-strong-random-secret-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
JWT_REFRESH_DAYS=30

# Admin bootstrap (first run only)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=
INITIAL_ADMIN_FULLNAME=مدیر نکسورانود

# 3X-UI Panel
XUI_HOST=https://p.nexoranode.xyz:2087
XUI_PATH=/CC6AiFGmYY4ZWVRf08
XUI_USERNAME=
XUI_PASSWORD=
XUI_TOKEN=
XUI_SUB_BASE_URL=https://s.nexoranode.xyz:2096/s/
XUI_WS_INBOUND_NAME=NX-WS
XUI_REALITY_INBOUND_NAME=NX-Reality

# Telegram Bot
BOT_TOKEN=
BOT_API_URL=https://api.telegram.org/bot

# Panel
FRONTEND_URL=https://manage.nexoranode.xyz:2053
BOT_ROOT=/bot
BOT_ROOT_HOST=/opt/nexoranode-bot
# Writable plans path inside panel container
PLANS_FILE=/data/plans/plans.json
# Host directory mounted rw — MUST match bot volume (app/data/plans.json on host)
PLANS_DIR_HOST=/opt/nexoranode-bot/app/data
# Bot must mount the same file in deploy/docker-compose.prod.yml:
#   - ../app/data/plans.json:/app/data/plans.json:rw
# Bot reloads plans automatically when the file changes (no restart needed).

# Payment (read-only in settings UI)
CARD_NUMBER=
CARD_OWNER=
CARD_BANK=

# Referral
REFERRAL_BONUS_TOMAN=8000
REFERRAL_FRIEND_BONUS_TOMAN=5000
QUANTITY_MAX=20

# Frontend build
NEXT_PUBLIC_API_URL=https://manage.nexoranode.xyz:2053/api
NEXT_PUBLIC_APP_NAME=Nexoranode Admin

# CSRF
CSRF_SECRET=generate-csrf-secret-here
